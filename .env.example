# ===========================================================================
# CSIT5900 Multi-turn Homework Tutoring Agent - Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your actual credentials.

# ---------------------------------------------------------------------------
# Azure OpenAI API Configuration (Mandatory for Project Submission)
# ---------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ---------------------------------------------------------------------------
# One API Configuration (OpenAI-compatible, for Self-Testing)
# ---------------------------------------------------------------------------
ONEAPI_API_KEY=your-oneapi-key-here
ONEAPI_BASE_URL=https://your-oneapi-endpoint.com/v1
ONEAPI_MODEL_NAME=gpt-4o

# ---------------------------------------------------------------------------
# LLM Backend Selection: "azure" or "oneapi"
# ---------------------------------------------------------------------------
LLM_BACKEND=azure
